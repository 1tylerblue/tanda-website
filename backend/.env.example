PORT=3000
LEAD_RATE_LIMIT_WINDOW_MS=900000
LEAD_RATE_LIMIT_MAX=8
MIN_FORM_FILL_MS=2500

# Optional, comma-separated extra frontend origins
# ALLOWED_ORIGINS=https://app.example.com,https://admin.example.com

# Quote email delivery (recommended: Gmail app password)
QUOTE_TO_EMAIL=tandaprocleaning@gmail.com
QUOTE_FROM_EMAIL=tandaprocleaning@gmail.com
SMTP_USER=tandaprocleaning@gmail.com
GMAIL_APP_PASSWORD=your_gmail_app_password

# Optional custom SMTP instead of Gmail
# SMTP_HOST=smtp.yourprovider.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_PASS=your_smtp_password
